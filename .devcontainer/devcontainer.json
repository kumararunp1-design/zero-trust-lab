{
  "name": "Zero Trust Lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "dockerDashComposeVersion": "v2",
      "installDockerBuildx": true
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "runArgs": ["--privileged"],
  "forwardPorts": [3000, 5000, 8080, 8181, 8888, 5601],
  "portsAttributes": {
    "3000": { "label": "Frontend App", "onAutoForward": "notify" },
    "5000": { "label": "Backend API", "onAutoForward": "notify" },
    "8080": { "label": "Keycloak IdP", "onAutoForward": "notify" },
    "8181": { "label": "OPA Policy Engine", "onAutoForward": "silent" },
    "8888": { "label": "Vulnerable App (Lab Target)", "onAutoForward": "notify" },
    "5601": { "label": "SIEM Dashboard", "onAutoForward": "notify" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "tsandall.opa",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
